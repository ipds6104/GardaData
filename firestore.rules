rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }

    match /classifications/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /village_stats/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /infrastructure_items/{id} {
      allow read: if true;
      allow write: if true;
    }
  }
}
